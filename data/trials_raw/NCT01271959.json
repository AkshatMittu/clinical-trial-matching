    "outcomesModule": {
      "primaryOutcomes": [
        {
          "measure": "To determine physicians' rate of compliance with ChemoFx assay results in the treatment of subjects with solid tumors.",
          "timeFrame": "Analysis of assay-directed compliance will be conducted immediately after information is collected."
        },
        {
          "measure": "To investigate the association between the results of Precision's ChemoFx assay results and overall survival in subjects with solid tumors.",
          "timeFrame": "From date of first dose of on-study chemotherapy to date of death or last known alive."
        }
      ]
    },
    "eligibilityModule": {
      "eligibilityCriteria": "Inclusion Criteria:\n\n* Pathologically confirmed diagnosis of solid tumor malignancy;\n* Medically indicated to receive chemotherapy;\n* Fresh tissue submitted from the solid tumor malignancy for testing with the ChemoFx\u00ae assay after August, 2006;\n* Final ChemoFx\u00ae assay report is available;\n* Subject must be at least 18 years of age;\n* Subject must sign and date an IRB approved ICF.\n\nExclusion Criteria:\n\n* Enrolled in PT-103, PT-106, PT-206, PT-301, or PT-304;\n* Pregnant or lactating subjects;\n* Subjects are not indicated to receive chemotherapy for their disease;\n* Subjects with psychiatric or addictive disorders that would preclude obtaining informed consent.",

        {
          "label": "TN11-1: TNBC patients predicted sensitive to Paclitaxel+Carboplatin+Camrelizumab+Famitinib by AI",
          "type": "EXPERIMENTAL",
          "description": "The TN11 arm explores AI-guided multidisciplinary precision therapy in TNBC. Patients are stratified using an established digital pathology-based AI model that predicts sensitivity to the combination therapy of Paclitaxel, Carboplatin, Camrelizumab and Famitinib. Patients predicted to be sensitive (TN11-1) receive this combination therapy directly.",
          "interventionNames": [
            "Drug: Camrelizumab",
            "Drug: Carboplatin",
            "Drug: Famitinib",
            "Drug: paclitaxel"
          ]
        },
        {
          "label": "TN11-2: TNBC patients predicted non-sensitive to Paclitaxel+Carboplatin+Camrelizumab+Famitinib by AI",
          "type": "EXPERIMENTAL",
          "description": "TNBC patients predicted to be non-sensitive (TN11-2) to the combination therapy of Paclitaxel, Carboplatin, Camrelizumab and Famitinib first undergo stereotactic body radiation therapy (SBRT). SBRT is delivered to the primary tumor in 3 fractions of 8 Gy (total 24 Gy) over 3-5 days. Following SBRT, patients receive the combination therapy of Paclitaxel, Carboplatin, Camrelizumab and Famitinib.",
          "interventionNames": [
            "Drug: Camrelizumab",
            "Drug: Carboplatin",
            "Drug: Famitinib",
            "Drug: paclitaxel",
            "Radiation: Stereotactic Body Radiation Therapy (SBRT)"
          ]
        },
        {
          "label": "L12",
          "type": "EXPERIMENTAL",
          "description": "Patients with HR+HER2- breast cancer, clinical stage cT1c-4, cN0-3, M0, with either tumor grade \u22652 or Ki-67 \u226520%. Patients first undergo stereotactic body radiotherapy (SBRT) to the primary tumor, followed by combination therapy of Paclitaxel + Epirubicin + Cyclophosphamide + Camrelizumab + Famitinib.",
          "interventionNames": [
            "Drug: Camrelizumab",
            "Drug: Epirubicin",
            "Drug: Cyclophosphamide",
            "Drug: Famitinib",
            "Drug: paclitaxel",
            "Radiation: Stereotactic Body Radiation Therapy (SBRT)"
          ]
        }
      ],

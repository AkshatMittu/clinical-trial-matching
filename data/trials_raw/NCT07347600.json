    "descriptionModule": {
      "briefSummary": "The main purpose of this study is to evaluate the effectiveness of inavolisib based regimen in participants with endocrine-resistant, phosphatidylinositol-4,5-bisphosphate 3-kinase catalytic subunit alpha gene (PIK3CA)-mutated, hormone receptor-positive (HR+), human epidermal growth factor receptor 2-negative (HER2-) locally advanced or metastatic breast cancer (LA/mBC), following on or after completing adjuvant endocrine therapy in routine clinical practice in China."
    },
    "conditionsModule": {
      "conditions": [
        "Locally Advanced Breast Cancer",
        "Metastatic Breast Cancer"
      ]
    },

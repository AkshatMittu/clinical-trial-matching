    "armsInterventionsModule": {
      "armGroups": [
        {
          "label": "Standard",
          "type": "NO_INTERVENTION",
          "description": "Radiotherapy to the remaining breast after breast conserving surgery or chest wall after mastectomy, and regional axillary lymph node levels I-IV. Internal mammary nodes are included in the target volume if the tumor has a central/medial localization in the breast."
        },
        {
          "label": "Intervention",
          "type": "EXPERIMENTAL",
          "description": "No regional radiotherapy. Radiotherapy is given to the remaining breast after breast conserving surgery. Chest wall radiotherapy after mastectomy only in case of wide spread multifocality.",
